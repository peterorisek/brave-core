if (is_mac) {
  # Bundles the prebuilt Metal GPU accelerator into the app's Libraries dir so
  # the sandboxed on-device-model utility process can dlopen it (Seatbelt only
  # allows the bundle), mirroring optimization_guide_library. The embedder finds
  # it via FrameworkBundlePath()/Libraries.
  # TODO(litert-poc): the .dylib is currently the locally-materialized prebuilt;
  # replace with component/DEPS delivery.
  bundle_data("litert_metal_accelerator_bundle_data") {
    sources = [ "//third_party/litert/src/litert/prebuilt/macos_arm64/libLiteRtMetalAccelerator.dylib" ]
    outputs = [ "{{bundle_contents_dir}}/Libraries/{{source_file_part}}" ]
  }
}

if (is_mac) {
  # metal_info.cc is Objective-C++ (imports <Metal/Metal.h>, uses ARC) despite
  # its .cc extension, so it needs its own target to force the ObjC++ language
  # and link the Metal/Foundation frameworks. Only the Metal device handle lives
  # here; the rest of the LiteRT runtime talks to it through metal_info.h's C
  # ABI. Enabled by the Metal support patch to
  # //third_party/litert:litert_config and injected into litert_runtime via
  # sources.gni.
  source_set("litert_metal_info") {
    sources = [ "//third_party/litert/src/litert/runtime/metal_info.cc" ]
    cflags = [
      "-x",
      "objective-c++",
      "-fobjc-arc",
    ]
    frameworks = [
      "Metal.framework",
      "Foundation.framework",
    ]
    deps = [ "//third_party/litert:litert_headers" ]
    configs -= [ "//build/config/compiler:chromium_code" ]
    configs += [
      "//build/config/compiler:no_chromium_code",
      "//build/config/compiler:rtti",
    ]
    visibility = [ "//third_party/litert:*" ]
  }
}
